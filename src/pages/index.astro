<!-- ══════════════════════════════════════════
     Horizontal pin-scroll engine (~180 bytes)
══════════════════════════════════════════ -->
<script is:inline>
  (function () {
    var section  = document.getElementById("h-scroll-section");
    var track    = document.getElementById("h-scroll-track");
    var bar      = document.getElementById("h-progress-bar");
    if (!section || !track) return;

    function update() {
      var rect        = section.getBoundingClientRect();
      var sectionH    = section.offsetHeight - window.innerHeight;
      if (rect.top > 0 || rect.bottom < window.innerHeight) return;

      var progress    = Math.min(1, Math.max(0, -rect.top / sectionH));
      var maxSlide    = -(track.scrollWidth - window.innerWidth + window.innerWidth * 0.1);
      track.style.transform = "translateX(calc(5vw + " + (progress * maxSlide) + "px))";
      if (bar) bar.style.width = (progress * 100) + "%";
    }

    window.addEventListener("scroll",  update, { passive: true });
    window.addEventListener("resize",  update, { passive: true });
    update();
  })();

  /* Parallax scroll tracker */
  (function () {
    var root = document.documentElement;
    function tick() { root.style.setProperty("--scroll-y", window.scrollY + "px"); }
    window.addEventListener("scroll", tick, { passive: true });
  })();
</script>
