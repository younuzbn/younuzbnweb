---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found — Younuz Bin Noushad | Best Software Engineer in Kochi"
  description="Page not found. Return to Younuz Bin Noushad's portfolio — CTO Adnora Solutions, Founder Kochi.one, best software engineer in Kochi, Kerala."
  path="/404/"
>
  <main style="min-height: 80vh; display: flex; align-items: center;">
    <div class="shell" style="padding: 8rem 0; text-align: center; width: 100%;">

      <p style="font-size: clamp(6rem, 20vw, 14rem); font-weight: 900; letter-spacing: -0.06em; line-height: 1; margin: 0 0 1rem 0; color: var(--gray-100);" aria-hidden="true">
        404
      </p>

      <h1 style="font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 700; letter-spacing: -0.03em; margin: 0 0 1rem 0;">
        Page Not Found
      </h1>

      <p class="t-body" style="max-width: 34rem; margin: 0 auto 2.5rem auto; color: var(--gray-500);">
        This page doesn't exist. Head back to find the best software engineer in Kochi, Kerala — 
        or explore projects, about page, and contact info.
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="pill pill-dark" style="padding: 0.65rem 1.5rem; font-size: 0.875rem;">
          ← Back to Home
        </a>
        <a href="/projects/" class="pill" style="padding: 0.65rem 1.5rem; font-size: 0.875rem;">
          View Projects ↗
        </a>
        <a href="/about/" class="pill" style="padding: 0.65rem 1.5rem; font-size: 0.875rem;">
          About & Contact ↗
        </a>
      </div>

      <p class="t-micro" style="margin: 3rem auto 0; color: var(--gray-400);">
        <strong>Younuz Bin Noushad</strong> · CTO Adnora Solutions · Founder Kochi.one · Kochi, Kerala
      </p>

    </div>
  </main>
</BaseLayout>
