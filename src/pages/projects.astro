---
import BaseLayout from "../layouts/BaseLayout.astro";

const tracks = [
  {
    icon: "◆",
    title: "Native Product Systems",
    body: "iOS and macOS applications built with Swift and SwiftUI — platform-fidelity UX, stable architecture, and enterprise reliability."
  },
  {
    icon: "◈",
    title: "Spatial & Immersive Interfaces",
    body: "AR/VR-led product modules built on ARKit and RealityKit — interaction quality and rendering efficiency at the forefront."
  },
  {
    icon: "◇",
    title: "Performance-Led Refactors",
    body: "Architecture simplification, payload reduction, and runtime tuning for software that must feel instant under real-world conditions."
  },
];

const principles = [
  { label: "Payload first",        note: "Every build targets the smallest possible footprint." },
  { label: "Native APIs",          note: "Platform primitives before framework abstractions." },
  { label: "Profiling-driven",     note: "Decisions backed by measurement, not assumption." },
  { label: "Long-term maintainability", note: "Code boundaries that survive team and feature growth." },
];
---

<BaseLayout
  title="Projects by Younuz Bin Noushad | iOS, AR/VR, SaaS — Best Engineer Kochi"
  description="Projects by Younuz Bin Noushad — kochi.one city platform, iOS apps, AR/VR, SaaS products, and open source. CTO at Adnora Solutions, the best tech company in Kochi, Kerala."
  path="/projects/"
  breadcrumbs={[{ name: "Projects", item: "/projects/" }]}
>
  <main>

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="relative overflow-hidden" style="min-height: 60vh; display: flex; align-items: center;">

      <div class="parallax-orb parallax-fast"
           style="width: 50vw; height: 50vw; top: -15%; right: -15%;"
           aria-hidden="true"></div>

      <div class="shell py-24 relative" style="z-index: 1;">
        <span class="t-kicker fade-up mb-5">Products · Ventures · Company Work</span>
        <h1 class="t-display fade-up fade-up-1 mb-6">Projects</h1>
        <p class="t-body fade-up fade-up-2" style="max-width: 38rem;">
          City platforms, enterprise tech products, spatial computing concepts, and
          performance-engineered software — built from Kochi, Kerala.
        </p>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         FEATURED AR/VR PROJECT — DARK
    ══════════════════════════════════════════ -->
    <div class="divider"></div>
    <section class="bg-dark py-20">
      <div class="shell">

        <div class="scroll-reveal">
          <span class="t-kicker mb-5" style="color: rgba(255,255,255,0.4);">Featured</span>

          <div class="grid lg:grid-cols-2 gap-12 items-start">
            <div>
              <h2 style="font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 700; letter-spacing: -0.035em; line-height: 1.06; color: white; margin: 0 0 1.25rem 0;">
                Spatial Commerce Navigator
              </h2>
              <p style="font-size: 1.0625rem; line-height: 1.8; color: rgba(255,255,255,0.55); margin: 0 0 2rem 0; max-width: 36rem;">
                A pro-level AR/VR concept blending real-time product visualization, motion-tracked interaction design,
                and an ultra-light native rendering pipeline. Built for enterprise retail on Apple platforms.
              </p>
              <div class="flex flex-wrap gap-2">
                {["ARKit", "RealityKit", "SwiftUI", "Metal", "Native iOS"].map((t) => (
                  <span style="display: inline-flex; padding: 0.3rem 0.85rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                    {t}
                  </span>
                ))}
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              {[
                { n: "60fps",    label: "Target frame rate" },
                { n: "<1MB",     label: "Core bundle size" },
                { n: "ARKit 6",  label: "Tracking engine" },
                { n: "Real-time", label: "Rendering mode" },
              ].map((item) => (
                <div style="border: 1px solid rgba(255,255,255,0.09); border-radius: 1.25rem; padding: 1.5rem;">
                  <p style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; letter-spacing: -0.04em; color: white; margin: 0 0 0.25rem 0;">{item.n}</p>
                  <p style="font-size: 0.75rem; color: rgba(255,255,255,0.45); margin: 0;">{item.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </section>
    <div class="divider"></div>


    <!-- ══════════════════════════════════════════
         KOCHI.ONE — FEATURED VENTURE
    ══════════════════════════════════════════ -->
    <section class="shell py-20 scroll-reveal">
      <span class="t-kicker mb-6">Founder · Live Product</span>

      <div class="card-dark" style="padding: 3rem 3.25rem; position: relative; overflow: hidden;">
        <!-- decorative bg word -->
        <p aria-hidden="true" style="position:absolute;right:-1rem;top:-2rem;font-size:clamp(5rem,12vw,10rem);font-weight:900;letter-spacing:-0.06em;color:rgba(255,255,255,0.04);line-height:1;pointer-events:none;user-select:none;">
          KOCHI
        </p>

        <div class="grid lg:grid-cols-2 gap-12 items-start relative" style="z-index:1;">
          <div>
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;flex-wrap:wrap;">
              <h2 style="font-size:clamp(2rem,4vw,3.25rem);font-weight:700;letter-spacing:-0.035em;line-height:1.06;color:white;margin:0;">
                kochi.one
              </h2>
              <a href="https://www.kochi.one" target="_blank" rel="noopener noreferrer"
                 style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1.125rem;border-radius:999px;background:white;color:black;font-size:0.8125rem;font-weight:600;text-decoration:none;white-space:nowrap;flex-shrink:0;">
                Visit ↗
              </a>
            </div>
            <p style="font-size:1.0625rem;line-height:1.8;color:rgba(255,255,255,0.55);margin:0 0 2rem 0;max-width:36rem;">
              Your Gateway to Everything Kochi — a city-wide digital platform covering events, tourism, dining,
              fitness, transit, and real-time business intelligence for Kochi, Kerala. Includes a native mobile app
              and live city reports.
            </p>
            <div class="flex flex-wrap gap-2">
              {["City Platform", "Events", "Tourism", "Mobile App", "Real-time Data", "Kochi, Kerala"].map((t) => (
                <span style="display:inline-flex;padding:0.3rem 0.85rem;border-radius:999px;font-size:0.75rem;font-weight:600;border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);">
                  {t}
                </span>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            {[
              { n: "Founder", label: "Role" },
              { n: "City-wide", label: "Scale" },
              { n: "Mobile App", label: "Delivery" },
              { n: "Live", label: "Status" },
            ].map((item) => (
              <div style="border:1px solid rgba(255,255,255,0.09);border-radius:1.25rem;padding:1.5rem;">
                <p style="font-size:clamp(1.25rem,2.5vw,1.875rem);font-weight:700;letter-spacing:-0.04em;color:white;margin:0 0 0.25rem 0;">{item.n}</p>
                <p style="font-size:0.75rem;color:rgba(255,255,255,0.45);margin:0;">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
    <div class="divider"></div>


    <!-- ══════════════════════════════════════════
         PROJECT TRACKS
    ══════════════════════════════════════════ -->
    <section class="shell py-20">

      <div class="scroll-reveal mb-10">
        <span class="t-kicker mb-3">Categories</span>
        <h2 class="t-headline" style="max-width: 18ch;">Project Tracks</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4 scroll-stagger">
        {tracks.map((t) => (
          <article class="card p-7">
            <p style="font-size: 1.75rem; margin: 0 0 1rem 0; line-height: 1;" aria-hidden="true">{t.icon}</p>
            <h3 class="t-title mb-3">{t.title}</h3>
            <p class="t-small m-0">{t.body}</p>
          </article>
        ))}
      </div>

    </section>


    <!-- ══════════════════════════════════════════
         ADNORA SOLUTIONS — COMPANY WORK
    ══════════════════════════════════════════ -->
    <section class="shell py-20 scroll-reveal">
      <span class="t-kicker mb-6">CTO · Company Work</span>
      <div style="display:grid;gap:1.25rem;">

        <!-- Main Adnora card -->
        <article class="card" style="padding:2.5rem 3rem;">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;margin-bottom:1.75rem;">
            <div>
              <h2 style="font-size:clamp(1.75rem,3vw,2.5rem);font-weight:700;letter-spacing:-0.035em;line-height:1.1;margin:0 0 0.375rem 0;">
                Adnora Solutions
              </h2>
              <p style="font-size:0.875rem;color:var(--gray-500);margin:0;font-weight:500;">Best Tech Company in Kochi, Kerala</p>
            </div>
            <span style="display:inline-flex;padding:0.4rem 1rem;border-radius:999px;font-size:0.75rem;font-weight:700;background:var(--black);color:white;letter-spacing:0.02em;white-space:nowrap;flex-shrink:0;">
              CTO
            </span>
          </div>
          <p class="t-body" style="margin:0 0 2rem 0;max-width:52rem;">
            As CTO at Adnora Solutions, leading end-to-end product engineering across webapp, mobile app,
            SaaS platform development, and custom software projects for clients locally and globally.
            Adnora Solutions is the best technology company in Kochi — built on a philosophy of quality,
            performance, and product-first thinking.
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {[
              { icon: "⬡", title: "Web Apps", body: "Modern, performant web application development" },
              { icon: "⬡", title: "Mobile Apps", body: "iOS & Android native and cross-platform apps" },
              { icon: "⬡", title: "SaaS Products", body: "Scalable software-as-a-service platforms" },
              { icon: "⬡", title: "Custom Software", body: "Bespoke enterprise software solutions" },
            ].map((s) => (
              <div class="card-fill" style="padding:1.25rem;">
                <p style="font-size:0.8125rem;font-weight:700;margin:0 0 0.375rem 0;">{s.title}</p>
                <p style="font-size:0.75rem;color:var(--gray-500);margin:0;line-height:1.6;">{s.body}</p>
              </div>
            ))}
          </div>
        </article>

      </div>
    </section>
    <div class="divider"></div>


    <!-- ══════════════════════════════════════════
         DELIVERY PRINCIPLES
    ══════════════════════════════════════════ -->
    <section class="shell py-20">

      <div class="scroll-reveal mb-10">
        <span class="t-kicker mb-3">Standards</span>
        <h2 class="t-headline" style="max-width: 20ch;">Delivery Principles for Every Build</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 scroll-stagger">
        {principles.map((p) => (
          <article class="card-fill p-6">
            <p style="font-size: 1rem; font-weight: 600; letter-spacing: -0.01em; margin: 0 0 0.5rem 0;">{p.label}</p>
            <p class="t-small m-0">{p.note}</p>
          </article>
        ))}
      </div>

    </section>


    <!-- ══════════════════════════════════════════
         CTA
    ══════════════════════════════════════════ -->
    <div class="divider"></div>
    <section class="shell py-20">
      <div class="scroll-reveal">
        <h2 class="t-headline mb-4" style="max-width: 22ch;">
          Interested in working together?
        </h2>
        <p class="t-body mb-8" style="max-width: 36rem;">
          Reach out directly — every collaboration starts with a clear brief and a shared standard for quality.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/about/" class="pill pill-dark" style="padding: 0.6rem 1.4rem; font-size: 0.875rem;">
            About & Contact ↗
          </a>
          <a href="https://github.com/younuzbn" target="_blank" rel="noopener noreferrer"
             class="pill" style="padding: 0.6rem 1.4rem; font-size: 0.875rem;">
            GitHub Profile ↗
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
